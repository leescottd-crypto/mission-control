DATABASE_URL="file:./dev.db"

# For office-wide production use, switch DATABASE_URL to managed Postgres.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mission_control?sslmode=require"

CLICKUP_API_KEY=your_personal_clickup_api_token
CLICKUP_TEAM_ID=your_team_or_workspace_id
CLICKUP_SPACE_ID=optional_space_id

# Mission Control chat is deterministic and read-only.
# It does not call an embedded LLM.

# NetSuite (Token-Based Auth / OAuth 1.0a)
NETSUITE_ACCOUNT_ID=your_netsuite_account_id
NETSUITE_CONSUMER_KEY=your_netsuite_consumer_key
NETSUITE_CONSUMER_SECRET=your_netsuite_consumer_secret
NETSUITE_TOKEN_ID=your_netsuite_token_id
NETSUITE_TOKEN_SECRET=your_netsuite_token_secret

# Optional overrides
# NETSUITE_REALM=your_netsuite_account_id
# NETSUITE_BASE_URL=https://<account_id>.suitetalk.api.netsuite.com
# NETSUITE_HEALTH_PATH=/services/rest/record/v1/metadata-catalog?limit=1

# Runtime
# NODE_ENV=production
