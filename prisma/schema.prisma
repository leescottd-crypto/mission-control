// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WeekConfig {
  week          String @id // e.g. "2026-03-02"
  baseTarget    Float  @default(350)
  stretchTarget Float  @default(400)
}

model LeadConfig {
  id       String @id @default(cuid())
  week     String
  leadName String
  target   Float  @default(0)

  @@unique([week, leadName])
}

model ClientConfig {
  id         String  @id @default(cuid())
  week       String
  clientId   String
  clientName String?
  orderIndex Int     @default(0)
  team       Int?
  sa         String?
  dealType   String?
  min        Float?
  max        Float?
  target     Float?
  mtHrs      Float?
  wPlusHrs   Float?

  @@unique([week, clientId])
}

model ConsultantConfig {
  id               String @id @default(cuid())
  week             String
  consultantId     Int
  maxCapacity      Float  @default(40)
  billableCapacity Float  @default(40)
  mtHrs            Float  @default(0)
  wPlusHrs         Float  @default(0)
  notes            String @default("")

  @@unique([week, consultantId])
}

model CapacityGridConfig {
  week          String   @id
  resourcesJson String
  rowsJson      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EditableTask {
  id           String   @id @default(cuid())
  week         String
  scopeType    String
  scopeId      String
  sourceTaskId String?
  subject      String
  description  String   @default("")
  assignee     String   @default("")
  billableHoursToday Float @default(0)
  status       String   @default("backlog")
  position     Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  billableEntries TaskBillableEntry[]

  @@unique([week, scopeType, scopeId, sourceTaskId])
  @@index([week, scopeType, scopeId, status, position])
}

model TaskBillableEntry {
  id        String   @id @default(cuid())
  taskId     String
  entryDate String
  hours     Float    @default(0)
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      EditableTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, entryDate])
}

model TaskSidebarFolder {
  id        String   @id @default(cuid())
  name      String
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskSidebarBoard {
  id            String   @id @default(cuid())
  name          String
  parentFolderId String
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([parentFolderId, orderIndex])
}

model TaskSidebarHiddenBoard {
  id        String   @id @default(cuid())
  boardId   String   @unique
  createdAt DateTime @default(now())
}
